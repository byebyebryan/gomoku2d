rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validProfileKeys() {
      return request.resource.data.keys().hasAll([
        'auth_providers',
        'avatar_url',
        'created_at',
        'display_name',
        'email',
        'last_login_at',
        'preferred_variant',
        'recent_matches',
        'schema_version',
        'uid',
        'updated_at',
        'username',
      ]) && request.resource.data.keys().hasOnly([
        'auth_providers',
        'avatar_url',
        'created_at',
        'display_name',
        'email',
        'history_reset_at',
        'last_login_at',
        'preferred_variant',
        'recent_matches',
        'schema_version',
        'uid',
        'updated_at',
        'username',
      ]);
    }

    function nullableString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function hasHistoryResetAt(data) {
      return data.keys().hasAny(['history_reset_at']);
    }

    function validHistoryResetAtValue(data) {
      return !hasHistoryResetAt(data)
        || data.history_reset_at == null
        || data.history_reset_at is timestamp;
    }

    function validHistoryResetAtOnCreate() {
      return !hasHistoryResetAt(request.resource.data)
        || request.resource.data.history_reset_at == null
        || request.resource.data.history_reset_at == request.time;
    }

    function validHistoryResetAtOnUpdate() {
      return (
          !hasHistoryResetAt(resource.data)
          && !hasHistoryResetAt(request.resource.data)
        )
        || (
          hasHistoryResetAt(resource.data)
          && hasHistoryResetAt(request.resource.data)
          && request.resource.data.history_reset_at == resource.data.history_reset_at
        )
        || (
          hasHistoryResetAt(request.resource.data)
          && request.resource.data.history_reset_at == request.time
          && (
            !hasHistoryResetAt(resource.data)
            || resource.data.history_reset_at == null
            || request.resource.data.history_reset_at > resource.data.history_reset_at
          )
        );
    }

    function validProviders(value) {
      return value is list
        && value.size() > 0
        && value.size() <= 2
        && value.hasOnly(['google.com', 'github.com']);
    }

    function validRecentMatches(value) {
      return value is map
        && value.keys().hasAll(['matches', 'schema_version', 'updated_at'])
        && value.keys().hasOnly(['matches', 'schema_version', 'updated_at'])
        && value.schema_version == 1
        && value.matches is list
        && value.matches.size() <= 24
        && (
          value.updated_at == null
          || value.updated_at is timestamp
        );
    }

    function validRecentMatchesOnCreate() {
      return request.resource.data.recent_matches.updated_at == null;
    }

    function hasRecentMatches(data) {
      return data.keys().hasAny(['recent_matches']);
    }

    function recentMatchesChanged() {
      return !hasRecentMatches(resource.data)
        || request.resource.data.recent_matches != resource.data.recent_matches;
    }

    function validRecentMatchesOnUpdate() {
      return !recentMatchesChanged()
        || request.resource.data.recent_matches.updated_at == request.time;
    }

    function validProfileDocument(uid) {
      return validProfileKeys()
        && request.resource.data.schema_version == 2
        && request.resource.data.uid == uid
        && request.resource.data.uid is string
        && request.resource.data.display_name is string
        && request.resource.data.display_name.size() > 0
        && request.resource.data.display_name.size() <= 80
        && nullableString(request.resource.data.avatar_url, 2048)
        && nullableString(request.resource.data.email, 320)
        && nullableString(request.resource.data.username, 40)
        && validHistoryResetAtValue(request.resource.data)
        && validRecentMatches(request.resource.data.recent_matches)
        && request.resource.data.preferred_variant in ['freestyle', 'renju']
        && validProviders(request.resource.data.auth_providers)
        && request.resource.data.created_at is timestamp
        && request.resource.data.updated_at is timestamp
        && request.resource.data.last_login_at is timestamp;
    }

    function appOwnedProfileFieldsUnchanged() {
      return request.resource.data.created_at == resource.data.created_at
        && request.resource.data.username == resource.data.username;
    }

    function profileUpdateCooldownPassed() {
      return request.time >= resource.data.updated_at + duration.value(15, 'm');
    }

    function profileResetCooldownPassed() {
      return !hasHistoryResetAt(resource.data)
        || resource.data.history_reset_at == null
        || request.time >= resource.data.history_reset_at + duration.value(15, 'm');
    }

    function profileResetCooldownBypass() {
      return hasHistoryResetAt(request.resource.data)
        && request.resource.data.history_reset_at == request.time
        && (
          !hasHistoryResetAt(resource.data)
          || resource.data.history_reset_at == null
          || request.resource.data.history_reset_at > resource.data.history_reset_at
        )
        && profileResetCooldownPassed()
        && request.resource.data.recent_matches.matches.size() == 0
        && request.resource.data.recent_matches.updated_at == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'auth_providers',
          'avatar_url',
          'display_name',
          'email',
          'history_reset_at',
          'last_login_at',
          'preferred_variant',
          'recent_matches',
          'schema_version',
          'uid',
          'updated_at'
        ]);
    }

    function initialProfileSyncBypass() {
      return resource.data.created_at == resource.data.updated_at
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'auth_providers',
          'avatar_url',
          'display_name',
          'email',
          'last_login_at',
          'preferred_variant',
          'recent_matches',
          'schema_version',
          'uid',
          'updated_at'
        ]);
    }

    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && validProfileDocument(uid)
        && request.resource.data.username == null
        && request.resource.data.created_at == request.time
        && request.resource.data.updated_at == request.time
        && request.resource.data.last_login_at == request.time
        && validRecentMatchesOnCreate()
        && validHistoryResetAtOnCreate();
      allow update: if isOwner(uid)
        && validProfileDocument(uid)
        && appOwnedProfileFieldsUnchanged()
        && request.resource.data.updated_at == request.time
        && request.resource.data.last_login_at == request.time
        && validRecentMatchesOnUpdate()
        && (
          profileUpdateCooldownPassed()
          || profileResetCooldownBypass()
          || initialProfileSyncBypass()
        )
        && validHistoryResetAtOnUpdate();
      allow delete: if false;

      match /matches/{matchId} {
        allow read, write: if false;
      }
    }
  }
}
