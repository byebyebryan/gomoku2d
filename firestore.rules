rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function profileWriteKeys() {
      return [
        'auth',
        'created_at',
        'display_name',
        'match_history',
        'reset_at',
        'schema_version',
        'settings',
        'uid',
        'updated_at',
        'username',
      ];
    }

    function validProfileKeys() {
      return request.resource.data.keys().hasAll(profileWriteKeys())
        && request.resource.data.keys().hasOnly(profileWriteKeys());
    }

    function nullableString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function hasResetAt(data) {
      return data.keys().hasAny(['reset_at']);
    }

    function validResetAtValue(data) {
      return hasResetAt(data)
        && (data.reset_at == null || data.reset_at is timestamp);
    }

    function validResetAtOnCreate() {
      return request.resource.data.reset_at == null
        || request.resource.data.reset_at == request.time;
    }

    function validResetAtOnUpdate() {
      return (
          !hasResetAt(resource.data)
          && request.resource.data.reset_at == null
        )
        || (
          hasResetAt(resource.data)
          && request.resource.data.reset_at == resource.data.reset_at
        )
        || (
          request.resource.data.reset_at == request.time
          && (
            !hasResetAt(resource.data)
            || resource.data.reset_at == null
            || request.resource.data.reset_at > resource.data.reset_at
          )
        );
    }

    function validAuthProvider(provider) {
      return provider is map
        && provider.keys().hasAll(['avatar_url', 'display_name', 'provider'])
        && provider.keys().hasOnly(['avatar_url', 'display_name', 'provider'])
        && nullableString(provider.avatar_url, 2048)
        && nullableString(provider.display_name, 80)
        && provider.provider in ['google.com', 'github.com'];
    }

    function validAuthProviders(providers) {
      return providers is list
        && providers.size() > 0
        && providers.size() <= 2
        && validAuthProvider(providers[0])
        && (providers.size() == 1 || validAuthProvider(providers[1]));
    }

    function validAuth(value) {
      return value is map
        && value.keys().hasAll(['providers'])
        && value.keys().hasOnly(['providers'])
        && validAuthProviders(value.providers);
    }

    function validGameConfig(value) {
      return value is map
        && value.keys().hasAll(['opening', 'ruleset'])
        && value.keys().hasOnly(['opening', 'ruleset'])
        && value.opening == 'standard'
        && value.ruleset in ['freestyle', 'renju'];
    }

    function validBotPreset(value) {
      return value is map
        && value.keys().hasAll(['mode', 'preset', 'version'])
        && value.keys().hasOnly(['mode', 'preset', 'version'])
        && value.version == 1
        && value.mode == 'preset'
        && value.preset in ['easy', 'normal', 'hard'];
    }

    function validBotCustom(value) {
      return value is map
        && value.keys().hasAll([
          'depth',
          'extra_pass',
          'mode',
          'scoring',
          'version',
          'width',
        ])
        && value.keys().hasOnly([
          'depth',
          'extra_pass',
          'mode',
          'scoring',
          'version',
          'width',
        ])
        && value.version == 1
        && value.mode == 'custom'
        && value.depth in [1, 3, 5, 7]
        && (value.width == 'full' || value.width == 8 || value.width == 16)
        && value.scoring in ['simple', 'pattern']
        && value.extra_pass in ['none', 'corridor_proof'];
    }

    function validBot(value) {
      return validBotPreset(value) || validBotCustom(value);
    }

    function validTouchControl(value) {
      return value in ['pointer', 'touchpad'];
    }

    function validBoardHints(value) {
      return value is map
        && value.keys().hasAll(['immediate', 'imminent'])
        && value.keys().hasOnly(['immediate', 'imminent'])
        && value.immediate in ['off', 'win', 'win_threat']
        && value.imminent in ['off', 'threat', 'threat_counter'];
    }

    function validSettings(value) {
      return value is map
        && value.keys().hasAll(['board_hints', 'bot_config', 'game_config', 'touch_control'])
        && value.keys().hasOnly(['board_hints', 'bot_config', 'game_config', 'touch_control'])
        && validBoardHints(value.board_hints)
        && validBot(value.bot_config)
        && validGameConfig(value.game_config)
        && validTouchControl(value.touch_control);
    }

    function validMatchHistory(value) {
      return value is map
        && value.keys().hasAll(['archived_stats', 'replay_matches', 'summary_matches'])
        && value.keys().hasOnly(['archived_stats', 'replay_matches', 'summary_matches'])
        && value.replay_matches is list
        && value.replay_matches.size() <= 128
        && value.summary_matches is list
        && value.summary_matches.size() <= 1024
        && validArchivedMatchStats(value.archived_stats);
    }

    function validMatchHistoryOnCreate() {
      return request.resource.data.match_history.replay_matches.size() == 0
        && request.resource.data.match_history.summary_matches.size() == 0
        && emptyArchivedMatchStats(request.resource.data.match_history.archived_stats);
    }

    function validStatsCounter(value) {
      return value is map
        && value.keys().hasAll(['draws', 'losses', 'matches', 'moves', 'wins'])
        && value.keys().hasOnly(['draws', 'losses', 'matches', 'moves', 'wins'])
        && value.draws is int
        && value.draws >= 0
        && value.losses is int
        && value.losses >= 0
        && value.matches is int
        && value.matches >= 0
        && value.moves is int
        && value.moves >= 0
        && value.wins is int
        && value.wins >= 0;
    }

    function validArchivedMatchStats(value) {
      return value is map
        && value.keys().hasAll([
          'archived_before',
          'archived_count',
          'by_opponent_type',
          'by_ruleset',
          'by_side',
          'schema_version',
          'totals',
        ])
        && value.keys().hasOnly([
          'archived_before',
          'archived_count',
          'by_opponent_type',
          'by_ruleset',
          'by_side',
          'schema_version',
          'totals',
        ])
        && nullableString(value.archived_before, 40)
        && value.archived_count is int
        && value.archived_count >= 0
        && value.schema_version == 1
        && value.by_opponent_type is map
        && value.by_opponent_type.keys().hasAll(['bot', 'human'])
        && value.by_opponent_type.keys().hasOnly(['bot', 'human'])
        && value.by_ruleset is map
        && value.by_ruleset.keys().hasAll(['freestyle', 'renju'])
        && value.by_ruleset.keys().hasOnly(['freestyle', 'renju'])
        && value.by_side is map
        && value.by_side.keys().hasAll(['black', 'white'])
        && value.by_side.keys().hasOnly(['black', 'white'])
        && validStatsCounter(value.totals);
    }

    function emptyArchivedMatchStats(value) {
      return value.archived_before == null
        && value.archived_count == 0;
    }

    function validProfileDocument(uid) {
      return validProfileKeys()
        && request.resource.data.schema_version == 5
        && request.resource.data.uid == uid
        && request.resource.data.uid is string
        && request.resource.data.display_name is string
        && request.resource.data.display_name.size() > 0
        && request.resource.data.display_name.size() <= 80
        && nullableString(request.resource.data.username, 40)
        && validAuth(request.resource.data.auth)
        && validSettings(request.resource.data.settings)
        && validResetAtValue(request.resource.data)
        && validMatchHistory(request.resource.data.match_history)
        && request.resource.data.created_at is timestamp
        && request.resource.data.updated_at is timestamp;
    }

    function appOwnedProfileFieldsUnchanged() {
      return request.resource.data.created_at == resource.data.created_at
        && request.resource.data.username == resource.data.username;
    }

    function profileUpdateCooldownPassed() {
      return request.time >= resource.data.updated_at + duration.value(5, 'm');
    }

    function profileResetCooldownPassed() {
      return !hasResetAt(resource.data)
        || resource.data.reset_at == null
        || request.time >= resource.data.reset_at + duration.value(5, 'm');
    }

    function profileResetCooldownBypass() {
      return request.resource.data.reset_at == request.time
        && (
          !hasResetAt(resource.data)
          || resource.data.reset_at == null
          || request.resource.data.reset_at > resource.data.reset_at
        )
        && profileResetCooldownPassed()
        && validMatchHistoryOnCreate()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(profileWriteKeys());
    }

    function initialProfileSyncBypass() {
      return resource.data.created_at == resource.data.updated_at
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(profileWriteKeys());
    }

    match /profiles/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && validProfileDocument(uid)
        && request.resource.data.username == null
        && request.resource.data.created_at == request.time
        && request.resource.data.updated_at == request.time
        && validMatchHistoryOnCreate()
        && validResetAtOnCreate();
      allow update: if isOwner(uid)
        && validProfileDocument(uid)
        && appOwnedProfileFieldsUnchanged()
        && request.resource.data.updated_at == request.time
        && (
          profileUpdateCooldownPassed()
          || profileResetCooldownBypass()
          || initialProfileSyncBypass()
        )
        && validResetAtOnUpdate();
      allow delete: if isOwner(uid);

      match /matches/{matchId} {
        allow read, write: if false;
      }
    }
  }
}
