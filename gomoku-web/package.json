{
  "name": "gomoku-web",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "vite-plugin-top-level-await": {
      "uuid": "^14.0.0"
    }
  },
  "scripts": {
    "dev": "vite",
